{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/transcript/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/robots.txt",
      "dest": "public/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "public/sitemap.xml"
    },
    {
      "src": "/(.*\\.(html|css|js|svg|png|jpg|ico|xml|txt))",
      "dest": "public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
